  <property name="windowTitle">
   <string>Driving School</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* ═══ DRIVING SCHOOL — GLASSMORPHISM THEME ═══ */

QMainWindow {
  background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
    stop:0 #0d9488, stop:0.35 #14B8A6, stop:0.65 #2dd4c1, stop:1 #5eead4);
}
QWidget { font-family: &quot;Segoe UI&quot;, &quot;Helvetica Neue&quot;, Arial, sans-serif; font-size: 14px; color: #0f172a; }
QStackedWidget &gt; QWidget { background: transparent; }

/* ── Glass Cards ── */
QGroupBox {
  background: rgba(255,255,255,0.55); border: 1.5px solid rgba(255,255,255,0.80);
  border-radius: 20px; padding: 24px 20px 20px 20px; margin-top: 12px;
}
QGroupBox::title {
  subcontrol-origin: margin; left: 18px; padding: 3px 10px;
  color: #0f766e; font-weight: 800; font-size: 15px;
  background: rgba(255,255,255,0.70); border-radius: 8px;
}
QGroupBox#groupSignIn, QGroupBox#groupForgot {
  background: rgba(255,255,255,0.60); border: 1.5px solid rgba(255,255,255,0.85); border-radius: 22px;
}
QGroupBox#groupMedical {
  background: rgba(255,255,255,0.45); border: 1.5px dashed rgba(20,184,166,0.60);
  border-radius: 14px; padding: 14px;
}
QGroupBox#groupRequiredDocs {
  background: rgba(240,253,249,0.70); border: 1.5px dashed rgba(20,184,166,0.70);
  border-radius: 12px; padding: 14px; margin-top: 8px;
}
QGroupBox#groupRequiredDocs::title { color: #0d9488; font-weight: 800; font-size: 14px; }
QGroupBox#groupStep3Content { background: transparent; border: none; padding: 0; margin: 0; }
QGroupBox#groupDocs, QGroupBox#groupCourse {
  background: rgba(255,255,255,0.55); border: 1.5px solid rgba(255,255,255,0.80);
  border-radius: 18px; padding: 22px 18px 18px 18px; margin-top: 10px;
}
QGroupBox#groupDocs::title, QGroupBox#groupCourse::title {
  subcontrol-origin: margin; left: 16px; padding: 2px 10px;
  color: #0f766e; font-weight: 800; font-size: 15px;
  background: rgba(255,255,255,0.70); border-radius: 8px;
}
QGroupBox#groupFingerprint {
  background: rgba(255,255,255,0.55); border: 1.5px solid rgba(255,255,255,0.80);
  border-radius: 22px; padding: 36px;
}

/* ── Labels ── */
QLabel#labelAppTitle { font-size: 36px; font-weight: 900; color: #ffffff; margin-bottom: 2px; }
QLabel#labelAppSubtitle, QLabel#labelForgotSubtitle { font-size: 14px; color: rgba(255,255,255,0.85); font-style: italic; margin-bottom: 10px; }
QLabel#pageTitleStep1, QLabel#pageTitleStep2, QLabel#pageTitleStep3, QLabel#pageTitleStep4, QLabel#pageTitleForgot { font-size: 28px; font-weight: 900; color: #0f172a; margin-bottom: 2px; }
QLabel#labelStep1Sub, QLabel#labelStep2Sub, QLabel#labelStep3Sub, QLabel#labelStep4Sub { font-size: 14px; color: #374151; font-style: italic; margin-bottom: 8px; }
QLabel#labelSignInTitle { font-size: 22px; font-weight: 800; color: #0f172a; margin-bottom: 4px; }
QLabel#labelSignEmail, QLabel#labelSignPassword, QLabel#labelForgotEmail, QLabel#labelFirstName, QLabel#labelLastName, QLabel#labelDOB, QLabel#labelPhone, QLabel#labelCIN, QLabel#labelAddress, QLabel#labelCity, QLabel#labelEmail, QLabel#labelPassword, QLabel#labelConfirm { font-size: 12px; font-weight: 700; color: #374151; margin-top: 6px; margin-bottom: 2px; letter-spacing: 0.3px; }
QLabel#labelNoAccount { color: #374151; font-size: 13px; }
QLabel#labelFingerprintInstr { color: #374151; font-size: 14px; margin-bottom: 10px; }
QLabel#labelFingerprintStatus { color: #0d9488; font-weight: 700; margin-top: 8px; }
QLabel#labelNoDoc { color: #6B7280; font-size: 12px; font-style: italic; }

/* ── Glass Inputs ── */
QLineEdit, QDateEdit, QComboBox {
  background: rgba(255,255,255,0.45); border: 1.5px solid rgba(255,255,255,0.75);
  border-radius: 12px; padding: 11px 16px; color: #0f172a; font-size: 14px; font-weight: 500;
  selection-background-color: rgba(20,184,166,0.30);
}
QLineEdit:hover, QDateEdit:hover, QComboBox:hover {
  background: rgba(255,255,255,0.60); border: 1.5px solid rgba(20,184,166,0.60);
}
QLineEdit:focus, QDateEdit:focus, QComboBox:focus {
  background: rgba(255,255,255,0.85); border: 2px solid #14B8A6; color: #0f172a;
}
QLineEdit::placeholder { color: rgba(107,114,128,0.80); }
QDateEdit::up-button { subcontrol-origin: padding; subcontrol-position: top right; width: 18px; height: 13px; background: transparent; border: none; margin-right: 4px; margin-top: 3px; }
QDateEdit::up-button:hover { background: rgba(20,184,166,0.20); border-radius: 3px; }
QDateEdit::up-arrow { image: url(:/assets/arrow-up.svg); width: 10px; height: 10px; }
QDateEdit::down-button { subcontrol-origin: padding; subcontrol-position: bottom right; width: 18px; height: 13px; background: transparent; border: none; margin-right: 4px; margin-bottom: 3px; }
QDateEdit::down-button:hover { background: rgba(20,184,166,0.20); border-radius: 3px; }
QDateEdit::down-arrow { image: url(:/assets/arrow-down.svg); width: 10px; height: 10px; }


/* ── Checkboxes &amp; Radio Buttons ── */
QCheckBox, QRadioButton { padding: 8px 6px; color: #0f172a; font-size: 14px; font-weight: 500; spacing: 10px; }
QCheckBox:hover, QRadioButton:hover { color: #0d9488; }
QCheckBox::indicator { width: 22px; height: 22px; border-radius: 6px; border: 2px solid rgba(107,114,128,0.60); background: rgba(255,255,255,0.50); }
QCheckBox::indicator:hover { border-color: #14B8A6; background: rgba(20,184,166,0.15); }
QCheckBox::indicator:checked { background: qlineargradient(x1:0,y1:0,x2:1,y2:1,stop:0 #14B8A6,stop:1 #0d9488); border-color: #0d9488; image: url(:/assets/checkmark.svg); }
QRadioButton::indicator { width: 22px; height: 22px; border-radius: 11px; border: 2px solid rgba(107,114,128,0.60); background: rgba(255,255,255,0.50); }
QRadioButton::indicator:hover { border-color: #14B8A6; background: rgba(20,184,166,0.15); }
QRadioButton::indicator:checked { background: qlineargradient(x1:0,y1:0,x2:1,y2:1,stop:0 #14B8A6,stop:1 #0d9488); border-color: #0d9488; image: url(:/assets/radiodot.svg); }
QCheckBox#chkRemember { color: #374151; font-size: 13px; }

/* ── Buttons ── */
QPushButton { background: qlineargradient(x1:0,y1:0,x2:1,y2:0,stop:0 #14B8A6,stop:1 #0d9488); color: #ffffff; padding: 13px 28px; border-radius: 12px; border: none; font-weight: 800; font-size: 15px; min-height: 44px; }
QPushButton:hover { background: qlineargradient(x1:0,y1:0,x2:1,y2:0,stop:0 #2dd4c1,stop:1 #14B8A6); }
QPushButton:pressed { background: qlineargradient(x1:0,y1:0,x2:1,y2:0,stop:0 #0d9488,stop:1 #0a7e74); }
QPushButton#btnSignIn { background: rgba(15,23,42,0.85); border: 1px solid rgba(255,255,255,0.15); padding: 14px; font-size: 16px; border-radius: 14px; margin-top: 6px; }
QPushButton#btnSignIn:hover { background: rgba(30,41,59,0.90); }
QPushButton#btnSignIn:pressed { background: rgba(3,7,18,0.95); }
QPushButton#btnComplete { background: qlineargradient(x1:0,y1:0,x2:1,y2:0,stop:0 #14B8A6,stop:1 #0d9488); min-width: 200px; }
QPushButton#btnSendReset { background: rgba(15,23,42,0.85); border: 1px solid rgba(255,255,255,0.15); margin-top: 4px; }
QPushButton#btnSendReset:hover { background: rgba(30,41,59,0.90); }
QPushButton#btnCancel, QPushButton#btnPrev2, QPushButton#btnPrev3, QPushButton#btnPrev4 { background: rgba(107,114,128,0.70); border: 1.5px solid rgba(255,255,255,0.40); color: #ffffff; padding: 13px 28px; border-radius: 12px; min-height: 44px; font-weight: 700; font-size: 15px; }
QPushButton#btnCancel:hover, QPushButton#btnPrev2:hover, QPushButton#btnPrev3:hover, QPushButton#btnPrev4:hover { background: rgba(107,114,128,0.90); }
QPushButton#btnForgot { background: transparent; border: none; color: #0d9488; font-weight: 700; font-size: 13px; padding: 4px; min-height: 0; text-decoration: underline; }
QPushButton#btnForgot:hover { color: #14B8A6; background: transparent; }
QPushButton#btnCreateAccount { background: transparent; border: none; color: #0d9488; font-weight: 800; font-size: 14px; padding: 4px 8px; min-height: 0; text-decoration: underline; }
QPushButton#btnCreateAccount:hover { color: #14B8A6; background: transparent; }
QPushButton#btnBackToLogin { background: transparent; border: none; color: #374151; font-weight: 600; font-size: 13px; padding: 4px; min-height: 0; }
QPushButton#btnBackToLogin:hover { color: #0f172a; background: transparent; }
QPushButton#btnAutomate { background: rgba(255,255,255,0.25); border: 2px solid rgba(255,255,255,0.70); color: #0f172a; padding: 8px 20px; border-radius: 10px; font-weight: 800; font-size: 13px; min-height: 0; }
QPushButton#btnAutomate:hover { background: rgba(255,255,255,0.50); border-color: #ffffff; }
QPushButton#btnScanFingerprint { background: qlineargradient(x1:0,y1:0,x2:1,y2:0,stop:0 #14B8A6,stop:1 #0d9488); color: white; padding: 16px 28px; border-radius: 14px; font-size: 16px; font-weight: 800; min-width: 300px; border: none; }
QPushButton#btnScanFingerprint:hover { background: qlineargradient(x1:0,y1:0,x2:1,y2:0,stop:0 #2dd4c1,stop:1 #14B8A6); }
QPushButton#btnScanFingerprint:disabled { background: rgba(107,114,128,0.50); color: rgba(255,255,255,0.60); }
QPushButton#btnScanMed { background: qlineargradient(x1:0,y1:0,x2:1,y2:0,stop:0 #14B8A6,stop:1 #0d9488); color: #ffffff; padding: 12px; border-radius: 10px; font-weight: 700; }
QPushButton#btnScanMed:hover { background: qlineargradient(x1:0,y1:0,x2:1,y2:0,stop:0 #2dd4c1,stop:1 #14B8A6); }
QPushButton#btnVerifyCode { background: qlineargradient(x1:0,y1:0,x2:1,y2:0,stop:0 #14B8A6,stop:1 #0d9488); margin-top: 4px; }
QPushButton#btnVerifyCode:hover { background: qlineargradient(x1:0,y1:0,x2:1,y2:0,stop:0 #2dd4c1,stop:1 #14B8A6); }

/* ── Scrollbar ── */
QScrollBar:vertical { background: rgba(255,255,255,0.15); width: 8px; border-radius: 4px; }
QScrollBar::handle:vertical { background: rgba(255,255,255,0.45); border-radius: 4px; min-height: 30px; }
QScrollBar::handle:vertical:hover { background: rgba(255,255,255,0.70); }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }

/* ── Alert Labels ── */
QLabel#labelForgotEmailError, QLabel#labelVerifyError { background: rgba(254,242,242,0.80); color: #DC2626; border: 1.5px solid #FECACA; border-radius: 10px; padding: 8px 12px; font-size: 13px; font-weight: 700; margin-top: 2px; }
QLabel#labelCodeSent { background: rgba(240,253,249,0.80); color: #0f766e; border: 1.5px solid #5eead4; border-radius: 10px; padding: 10px 12px; font-size: 13px; font-weight: 700; margin-top: 4px; margin-bottom: 2px; }
QLabel#labelVerifyCodeTitle { font-size: 13px; font-weight: 700; color: #374151; margin-top: 6px; margin-bottom: 2px; }

/* ── Dialogs ── */
QMessageBox { background-color: #ffffff; }
QMessageBox QLabel { color: #0f172a; font-size: 14px; background: transparent; }
QMessageBox QPushButton { background: qlineargradient(x1:0,y1:0,x2:1,y2:0,stop:0 #14B8A6,stop:1 #0d9488); color: #ffffff; padding: 8px 24px; border-radius: 8px; border: none; font-weight: 700; font-size: 13px; min-width: 80px; min-height: 32px; }
QProgressDialog { background-color: #ffffff; }
QProgressDialog QLabel { color: #0f172a; font-size: 14px; background: transparent; }
QProgressDialog QPushButton { background: rgba(107,114,128,0.80); color: #ffffff; padding: 8px 20px; border-radius: 8px; border: none; font-weight: 700; font-size: 13px; min-height: 32px; }</string>

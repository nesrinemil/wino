  <property name="styleSheet">
   <string>
/* ── Root background ─────────────────────────── */
QMainWindow {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #0F766E, stop:0.5 #14B8A6, stop:1 #0891B2);
}
QWidget#centralwidget {
    background: transparent;
}

/* ── White panel ─────────────────────────────── */
QFrame#cardFrame {
    background-color: white;
    border-radius: 24px;
}

/* ── Brand title ─────────────────────────────── */
QLabel#titleLabel {
    color: #111827;
    font-size: 40px;
    font-weight: 800;
    font-family: 'Segoe UI', Arial;
    letter-spacing: 1px;
}

/* ── Sub-labels ──────────────────────────────── */
QLabel#subtitleLabel {
    color: #14B8A6;
    font-size: 15px;
    font-weight: 600;
    font-family: 'Segoe UI', Arial;
    letter-spacing: 0.5px;
}
QLabel#moduleLabel {
    color: #9CA3AF;
    font-size: 12px;
    font-family: 'Segoe UI', Arial;
    letter-spacing: 0.3px;
}

/* ── Divider ─────────────────────────────────── */
QFrame#divider {
    background-color: #F3F4F6;
    max-height: 1px;
    border: none;
}

/* ── Section heading ─────────────────────────── */
QLabel#chooseLabel {
    color: #6B7280;
    font-size: 13px;
    font-family: 'Segoe UI', Arial;
    letter-spacing: 1.5px;
}

/* ── Role buttons ────────────────────────────── */
QPushButton#adminButton {
    background-color: #FAFAFA;
    border: 2px solid #E5E7EB;
    border-radius: 18px;
    min-height: 170px;
    min-width: 170px;
    max-width: 190px;
}
QPushButton#adminButton:hover {
    background-color: #FDF4FF;
    border: 2px solid #A855F7;
}

QPushButton#studentButton {
    background-color: #FAFAFA;
    border: 2px solid #E5E7EB;
    border-radius: 18px;
    min-height: 170px;
    min-width: 170px;
    max-width: 190px;
}
QPushButton#studentButton:hover {
    background-color: #EFF6FF;
    border: 2px solid #3B82F6;
}

QPushButton#instructorButton {
    background-color: #FAFAFA;
    border: 2px solid #E5E7EB;
    border-radius: 18px;
    min-height: 170px;
    min-width: 170px;
    max-width: 190px;
}
QPushButton#instructorButton:hover {
    background-color: #F0FDFA;
    border: 2px solid #14B8A6;
}

/* ── Icon boxes ──────────────────────────────── */
QLabel#adminIcon {
    background-color: #F3E8FF;
    border-radius: 20px;
    min-width: 64px;
    max-width: 64px;
    min-height: 64px;
    max-height: 64px;
    font-size: 30px;
    color: #9333EA;
}
QLabel#studentIcon {
    background-color: #DBEAFE;
    border-radius: 20px;
    min-width: 64px;
    max-width: 64px;
    min-height: 64px;
    max-height: 64px;
    font-size: 30px;
    color: #3B82F6;
}
QLabel#instructorIcon {
    background-color: #CCFBF1;
    border-radius: 20px;
    min-width: 64px;
    max-width: 64px;
    min-height: 64px;
    max-height: 64px;
    font-size: 30px;
    color: #0D9488;
}

/* ── Role labels ─────────────────────────────── */
QLabel#adminTitle, QLabel#studentTitle, QLabel#instructorTitle {
    color: #111827;
    font-size: 15px;
    font-weight: 700;
    font-family: 'Segoe UI', Arial;
}
QLabel#adminSubtitle, QLabel#studentSubtitle, QLabel#instructorSubtitle {
    color: #9CA3AF;
    font-size: 11px;
    font-family: 'Segoe UI', Arial;
}

/* ── Footer version text ─────────────────────── */
QLabel#versionLabel {
    color: rgba(255,255,255,0.55);
    font-size: 11px;
    font-family: 'Segoe UI', Arial;
}
   </string>

   <string>QMainWindow {
    background-color: #F3F4F6;
}

#headerWidget {
    background-color: #14B8A6;
}

#headerTitle {
    color: white;
    font-size: 18px;
    font-weight: bold;
}

#headerSubtitle {
    color: rgba(255, 255, 255, 0.9);
    font-size: 13px;
}

#logoutButton {
    background-color: transparent;
    color: white;
    border: 2px solid white;
    border-radius: 5px;
    padding: 8px 20px;
    font-size: 13px;
    font-weight: bold;
}

#logoutButton:hover {
    background-color: rgba(255, 255, 255, 0.2);
}

#pageTitle {
    color: #1F1827;
    font-size: 24px;
    font-weight: bold;
}

#adminBadge {
    background-color: #14B8A6;
    color: white;
    border-radius: 5px;
    padding: 6px 12px;
    font-size: 12px;
    font-weight: bold;
}

.statCard {
    background-color: white;
    border-radius: 10px;
    padding: 15px;
}

.statLabel {
    color: #6B7280;
    font-size: 13px;
}

.statCount {
    color: #1F1827;
    font-size: 28px;
    font-weight: bold;
}

.filterButton {
    background-color: #E5E7EB;
    color: #6B7280;
    border: none;
    border-radius: 5px;
    padding: 10px 20px;
    font-size: 13px;
    font-weight: bold;
}

.filterButton:hover {
    background-color: #D1D5DB;
}

#scrollArea {
    border: none;
    background-color: transparent;
}

QScrollBar:vertical {
    border: none;
    background: #F3F4F6;
    width: 10px;
    border-radius: 5px;
}

QScrollBar::handle:vertical {
    background: #CBD5E0;
    border-radius: 5px;
}

QScrollBar::handle:vertical:hover {
    background: #A0AEC0;
}</string>
